<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net9.0-windows</TargetFramework>
		<Nullable>disable</Nullable>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
		<EnableWindowsFormsHighDpiAutoResizing>false</EnableWindowsFormsHighDpiAutoResizing>
		<AddSyntheticProjectReferencesForSolutionDependencies>false</AddSyntheticProjectReferencesForSolutionDependencies>
		<RestoreBuildInParallel>false</RestoreBuildInParallel>
	</PropertyGroup>

	<PropertyGroup Condition="'$(BuildingInsideVisualStudio)' == 'true'">
		<BaseOutputPath>bin\vs\</BaseOutputPath>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<NoWarn>1701;1702;WFO1000</NoWarn>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<NoWarn>1701;1702;WFO1000</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Theming\**" />
		<EmbeddedResource Remove="Theming\**" />
		<None Remove="Theming\**" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Drawing.Common" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="content\icons\toolbar\*.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>content\icons\toolbar\%(Filename)%(Extension)</TargetPath>
		</Content>
		<Content Include="content\icons\titlebar\*.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>content\icons\titlebar\%(Filename)%(Extension)</TargetPath>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\engine\helengine.core.windows\helengine.core.windows.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.baseplatform\helengine.baseplatform.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.core\helengine.core.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor.windows.gdiimporter\helengine.editor.windows.gdiimporter.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor.windows.pfimimporter\helengine.editor.windows.pfimimporter.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor.windows.magickimporter\helengine.editor.windows.magickimporter.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.files\helengine.files.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.input\helengine.input.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.bepu\helengine.bepu.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor.fbximporter\helengine.editor.assimp.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor.windows\helengine.editor.windows.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.editor\helengine.editor.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.directx11\helengine.directx11.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.platforms\helengine.platforms.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.projectfile\helengine.projectfile.csproj" SkipGetTargetFrameworkProperties="true" />
		<ProjectReference Include="..\..\engine\helengine.vulkan\helengine.vulkan.csproj" SkipGetTargetFrameworkProperties="true" />
	</ItemGroup>

</Project>
